# Runtime connection (pooled / Supavisor).
# Example (Supabase):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/DATABASE?pgbouncer=true"

# Direct connection for Prisma migrations/introspection (non-pooler host).
# Example (Supabase):
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/DATABASE"

# Public canonical site URL used for metadata, sitemap, and hreflang generation.
NEXT_PUBLIC_SITE_URL="https://www.islamicgoldenage.org"

# Minimal /admin protection for phase-1 editorial workflow (HTTP Basic Auth).
ADMIN_USERNAME="founder"
ADMIN_PASSWORD="change-me-now"
