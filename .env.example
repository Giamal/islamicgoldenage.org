# Primary database connection used by Prisma migrations and direct connections.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Direct connection is optional today but useful later for Prisma workflows that
# should bypass Supabase pooling when needed.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Public canonical site URL used for metadata, sitemap, and hreflang generation.
NEXT_PUBLIC_SITE_URL="https://www.islamicgoldenage.org"
