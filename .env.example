# Connect to Supabase via connection pooling.
# If your password includes '@', encode it as '%40'.
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD-URL-ENCODED]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct URL used by Prisma for migrations in this project setup.
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD-URL-ENCODED]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

NEXT_PUBLIC_SITE_URL="https://islamicgoldenage.org"
ADMIN_USERNAME="jamal"
ADMIN_PASSWORD="pass"


# Supabase Storage (server-side media upload).
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
